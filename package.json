    "openclaw": "workspace:*",
    "oxfmt": "0.35.0",
    "oxlint": "^1.50.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "engines": {
    "node": ">=22.12.0"
