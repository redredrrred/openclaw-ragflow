{
  "name": "openclaw-ragflow-knowledge",
  "version": "1.0.0",
  "description": "RAGFlow knowledge base integration plugin for OpenClaw",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": {
      "default": "./index.ts"
    },
