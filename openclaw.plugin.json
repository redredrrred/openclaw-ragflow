{
  "id": "ragflow-knowledge",
  "kind": "tool",
  "name": "RAGFlow Knowledge Base",
  "description": "Connect OpenClaw to RAGFlow knowledge bases for intelligent document retrieval and Q&A",
  "version": "1.0.0",
  "uiHints": {
    "apiUrl": {
      "label": "RAGFlow API URL",
      "placeholder": "http://localhost:80",
      "help": "RAGFlow server address (default: http://localhost:80)"
    },
    "apiKey": {
      "label": "API Key",
      "sensitive": true,
      "placeholder": "ragflow-xxxxxxxxxxxxxxxx",
      "help": "Get from RAGFlow Console → Profile → API"
    },
    "datasetIds": {
      "label": "Knowledge Base IDs",
      "help": "Array of dataset IDs to search (leave empty to search all). Configure as YAML array: ['dataset-1', 'dataset-2']"
    },
    "autoInject": {
      "label": "Auto-Inject Context",
      "help": "Automatically inject relevant knowledge into agent conversations"
    },
    "similarityThreshold": {
      "label": "Similarity Threshold",
      "placeholder": "0.1",
      "help": "Minimum similarity score (0-1, default: 0.1)",
      "advanced": true
    },
    "topK": {
      "label": "Max Results",
      "placeholder": "5",
      "help": "Maximum chunks to retrieve (default: 5)"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "RAGFlow API URL"
      },
      "apiKey": {
        "type": "string",
        "description": "RAGFlow API Key"
      },
      "datasetIds": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Dataset IDs to search"
      },
      "autoInject": {
        "type": "boolean",
        "description": "Auto-inject relevant knowledge"
      },
      "similarityThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "description": "Similarity threshold"
      },
      "topK": {
        "type": "number",
        "minimum": 1,
        "maximum": 50,
        "description": "Max results to return"
      }
    },
    "required": ["apiUrl", "apiKey"]
  }
}
